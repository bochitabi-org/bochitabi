{
	"cli": {
		"version": ">= 16.19.3",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"distribution": "internal"	
		},
		"dev-ios": {
			"extends": "development",
			"env": {
				"EXPO_PUBLIC_API_HOST": "localhost"
			},
			"ios": {
				"simulator": true
			}
		},
		"dev-android": {
			"extends": "development",
			"env": {
				"EXPO_PUBLIC_API_HOST": "10.0.2.2"
			},
			"android": {
				"buildType": "apk"
			}
		},
		"preview": {
			"distribution": "internal"
		},
		"production": {
			"autoIncrement": true
		}
	},
	"submit": {
		"production": {}
	}
}
