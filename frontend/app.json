{
	"expo": {
		"name": "ぼち旅（仮）",
		"slug": "frontend",
		"version": "0.0.1",
		"orientation": "portrait",
		"icon": "./assets/icon.png",
		"scheme": "bochitabi",
		"userInterfaceStyle": "light",
		"newArchEnabled": true,
		"splash": {
			"image": "./assets/splash-icon.png",
			"resizeMode": "contain",
			"backgroundColor": "#ffffff"
		},
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.masashi99.frontend",
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false
			}
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./assets/adaptive-icon.png",
				"backgroundColor": "#ffffff"
			},
			"edgeToEdgeEnabled": true,
			"predictiveBackGestureEnabled": false,
			"package": "com.masashi99.frontend"
		},
		"web": {
			"favicon": "./assets/favicon.png"
		},
		"extra": {
			"eas": {
				"projectId": "66e4b803-2864-4c7f-a986-c0969993e3c0"
			}
		},
		"plugins": ["expo-router"]
	}
}
